// Prisma Schema for Viral Shorts Dashboard

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Video {
  id            String   @id @default(cuid())
  platform      Platform
  videoId       String   @unique
  title         String
  description   String?
  thumbnailUrl  String
  videoUrl      String
  authorName    String?
  authorUrl     String?

  // Statistics
  viewCount     BigInt   @default(0)
  likeCount     BigInt   @default(0)
  shareCount    BigInt   @default(0)
  commentCount  BigInt   @default(0)

  // Viral tracking
  viewCountHistory Json   @default("[]") // [{date, count}, ...]
  viralScore       Float  @default(0)    // Growth rate score

  // Classification
  category      Category?
  targetAge     String?   // "10s", "20s", "30s", etc.
  tags          String[]
  country       String?   // "KR", "US", "JP", "Global" etc.

  // Metadata
  publishedAt   DateTime?
  collectedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([platform])
  @@index([category])
  @@index([country])
  @@index([viralScore(sort: Desc)])
  @@index([collectedAt(sort: Desc)])
}

enum Platform {
  YOUTUBE
  TIKTOK
  INSTAGRAM
}

enum Category {
  BEAUTY
  FOOD
  FASHION
  ELECTRONICS
  LIFESTYLE
  HEALTH
  KIDS
  OTHER
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String?
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  subscriptions Subscription[]

  @@index([email])
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  startAt   DateTime           @default(now())
  endAt     DateTime
  status    SubscriptionStatus @default(ACTIVE)
  amount    Int                @default(100000) // KRW
  memo      String?            // 입금자명 등 어드민 메모
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([userId])
  @@index([endAt])
  @@index([status])
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
}
