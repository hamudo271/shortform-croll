// Prisma Schema for Viral Shorts Dashboard

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Video {
  id            String   @id @default(cuid())
  platform      Platform
  videoId       String   @unique
  title         String
  description   String?
  thumbnailUrl  String
  videoUrl      String
  authorName    String?
  authorUrl     String?

  // Statistics
  viewCount     BigInt   @default(0)
  likeCount     BigInt   @default(0)
  shareCount    BigInt   @default(0)
  commentCount  BigInt   @default(0)

  // Viral tracking
  viewCountHistory Json   @default("[]") // [{date, count}, ...]
  viralScore       Float  @default(0)    // Growth rate score

  // Classification
  category      Category?
  targetAge     String?   // "10s", "20s", "30s", etc.
  tags          String[]
  country       String?   // "KR", "US", "JP", "Global" etc.

  // Metadata
  publishedAt   DateTime?
  collectedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([platform])
  @@index([category])
  @@index([country])
  @@index([viralScore(sort: Desc)])
  @@index([collectedAt(sort: Desc)])
}

enum Platform {
  YOUTUBE
  TIKTOK
  INSTAGRAM
}

enum Category {
  BEAUTY
  FOOD
  FASHION
  ELECTRONICS
  LIFESTYLE
  HEALTH
  KIDS
  OTHER
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  passwordHash   String
  name           String?
  role           Role           @default(USER)

  // B2B contact / business profile (유통업자 대상)
  phone          String?
  companyName    String?
  businessNumber String?        // 사업자등록번호 (123-45-67890)

  // Activity tracking
  lastLoginAt    DateTime?
  loginCount     Int            @default(0)

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  subscriptions  Subscription[]
  activityLogs   ActivityLog[]

  @@index([email])
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  startAt   DateTime           @default(now())
  endAt     DateTime
  status    SubscriptionStatus @default(ACTIVE)
  amount    Int                @default(100000) // KRW
  memo      String?            // 입금자명 등 어드민 메모
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([userId])
  @@index([endAt])
  @@index([status])
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // "LOGIN", "SIGNUP", "VIEW_PRODUCT", "SEARCH", ...
  metadata  Json?    // free-form context, e.g. { productId, query }
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([action])
  @@index([createdAt(sort: Desc)])
}
